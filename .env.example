# Copy to .env and edit paths for your machine.
# Loaded automatically after: bash scripts/install-conda-hook.sh && conda activate maf

MAF_ROOT=/path/to/maf

# Unity cluster (uncomment)
# CONDA_ENVS_PATH=/work/pi_dagarwal_umass_edu/project_16/eunbi/${USER}/.conda/envs
# CONDA_PKGS_DIRS=/work/pi_dagarwal_umass_edu/project_16/eunbi/${USER}/.conda/pkgs

# MindGames Efficient defaults
MAF_BASE_MODEL=Qwen/Qwen3-8B
MAF_LORA_4BIT=1
MAF_HF_CACHE=games/.cache/huggingface

# STARS (stars) — Ollama
STARS_OLLAMA_HOST=http://127.0.0.1:11434
STARS_OLLAMA_MODEL=qwen3:8b
